# Copy to .env for local development — never commit .env

DATABASE_URL=postgresql://ricemill:ricemill_dev@localhost:5432/ricemill
SECRET_KEY=change_this_to_a_long_random_string_minimum_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local dev — single origin
CORS_ORIGINS=["http://localhost:3000"]

